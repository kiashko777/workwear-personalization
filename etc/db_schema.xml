<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Customer logo storage -->
    <table name="workwear_customer_logo" resource="default" engine="innodb" comment="Workwear Customer Logos">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true" comment="Customer ID"/>
        <column xsi:type="varchar" name="file_path" length="255" nullable="false" comment="Relative file path under pub/media"/>
        <column xsi:type="smallint" name="status" unsigned="true" nullable="false" default="0" comment="0=Pending 1=Approved 2=Rejected"/>
        <column xsi:type="varchar" name="file_hash" length="64" nullable="false" comment="SHA-256 of file contents"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="WORKWEAR_CUSTOMER_LOGO_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="workwear_customer_logo" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id"
                    onDelete="SET NULL"/>
        <index referenceId="WORKWEAR_CUSTOMER_LOGO_FILE_HASH" indexType="btree">
            <column name="file_hash"/>
        </index>
        <index referenceId="WORKWEAR_CUSTOMER_LOGO_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
    </table>

    <!-- Per-product available embroidery/print positions -->
    <table name="workwear_product_position" resource="default" engine="innodb" comment="Workwear Product Personalization Positions">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="varchar" name="position_code" length="50" nullable="false" comment="Position code e.g. LEFT_CHEST"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="WORKWEAR_PRODUCT_POSITION_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID"
                    table="workwear_product_position" column="product_id"
                    referenceTable="catalog_product_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="WORKWEAR_PRODUCT_POSITION_PRODUCT_ID_POSITION_CODE">
            <column name="product_id"/>
            <column name="position_code"/>
        </constraint>
        <index referenceId="WORKWEAR_PRODUCT_POSITION_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
    </table>

    <!-- Extend quote_item: store personalization JSON -->
    <table name="quote_item" resource="checkout">
        <column xsi:type="text" name="personalization_data" nullable="true" comment="Workwear personalization JSON"/>
    </table>

    <!-- Extend sales_order_item: persist personalization JSON -->
    <table name="sales_order_item" resource="sales">
        <column xsi:type="text" name="personalization_data" nullable="true" comment="Workwear personalization JSON"/>
    </table>

</schema>
